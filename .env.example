# B 楼导航系统配置示例
# 复制此文件为 .env 并修改相应值

# ========== 服务器配置 ==========
# 服务器端口 (默认：8080)
PORT=8080

# 图数据文件路径 (默认：b_graph.jsonc)
GRAPH_PATH=b_graph.jsonc

# ========== 高德地图 API 配置 ==========
# 高德地图 API Key (可选，如果不设置则使用模拟数据)
# 获取方式：
# 1. 访问 https://lbs.amap.com/
# 2. 注册/登录账号
# 3. 进入控制台 https://console.amap.com/dev/key
# 4. 创建应用并添加 Key，服务平台选择 "Web 服务"
AMAP_API_KEY=your_amap_api_key_here

# ========== 宿舍楼位置配置 ==========
# 宿舍楼位置需要在 internal/amap/amap.go 中的 dormitoryLocations 变量中配置
# 支持的配置项：Name, Latitude(纬度), Longitude(经度), Address(地址)
# 如果未配置 API Key，系统将使用模拟的步行距离数据
