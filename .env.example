# B 楼导航系统配置示例
# 复制此文件为 .env 并修改相应值

# ========== 服务器配置 ==========
# 服务器端口 (默认：8080)
PORT=8080

# 图数据文件路径 (默认：b_graph.jsonc)
GRAPH_PATH=b_graph.jsonc

# ========== 高德地图 API 配置 ==========
# 注意：高德有两种 Key，需要分别申请：
# 1. Web 服务 API Key - 后端服务器调用路径规划接口
# 2. Web 端 (JS API) Key - 前端网页显示地图和绘制路线

# Web 服务 API Key（后端使用）
# 获取方式：https://lbs.amap.com/api/webservice/guide/api/direction
# 1. 访问高德开放平台
# 2. 注册/登录账号
# 3. 进入控制台创建应用
# 4. 添加 Key，服务平台选择 "Web 服务"
AMAP_API_KEY=your_amap_api_key_here

# Web 端 JS API Key（前端使用）
# 获取方式：https://lbs.amap.com/api/javascript-api/guide/qa/register
# 1. 访问高德开放平台
# 2. 进入控制台创建应用
# 3. 添加 Key，服务平台选择 "Web 端 (JS API)"
# 4. 安全密钥在控制台查看（需要在项目中配置）
AMAP_JS_API_KEY=your_amap_js_api_key_here

# Web 端安全密钥（与 JS API Key 配对使用）
# 在高德控制台的应用详情中查看
AMAP_SECURITY_CODE=your_amap_security_code_here
